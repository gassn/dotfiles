{
  "permissions": {
    "allow": [
      "Bash(*)",
      "Read(*)",
      "Write(*)",
      "Edit(*)",
      "WebFetch(*)",
      "WebSearch(*)",
      "mcp__postgres__query"
    ]
  },
  "enabledPlugins": {
    "frontend-design@claude-plugins-official": true,
    "code-simplifier@claude-plugins-official": true,
    "superpowers@claude-plugins-official": true,
    "context7@claude-plugins-official": true,
    "claude-md-management@claude-plugins-official": true,
    "hookify@claude-plugins-official": true,
    "context-mode@context-mode": true
  },
  "extraKnownMarketplaces": {
    "context-mode": {
      "source": {
        "source": "github",
        "repo": "mksglu/context-mode"
      }
    }
  },
  "language": "Japanese",
  "alwaysThinkingEnabled": true,
  "preferredNotifChannel": "terminal_bell",
  "hooks": {
    "SessionStart": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "SKILL_FILE=$(find ~/.claude/plugins/cache/context-mode -name 'SKILL.md' -path '*/skills/context-mode/*' -type f 2>/dev/null | head -1) && [ -f \"$SKILL_FILE\" ] && jq -n --arg ctx \"$(cat \"$SKILL_FILE\")\" '{\"hookSpecificOutput\":{\"hookEventName\":\"SessionStart\",\"additionalContext\":$ctx}}' 2>/dev/null || true",
            "timeout": 10,
            "statusMessage": "Loading context-mode..."
          }
        ]
      }
    ]
  }
}
